# Copy to .env.local and fill in values from Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: required for public profile graphs (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: canonical site URL for Open Graph / metadataBase (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=
