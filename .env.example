# Copy to .env.local and fill in values from Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: required for public profile graphs (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: canonical site URL for Open Graph / metadataBase
# Local: http://localhost:3000  |  Production: https://starmap.lol
NEXT_PUBLIC_SITE_URL=

# Server-only Gemini API key (used for "Import with AI" via /api/ai/extract-nodes)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
